# ============================================
# GITHUB CODEOWNERS MANAGER - CONFIGURAÇÕES
# ============================================

# --------------------------------------------
# AUTENTICAÇÃO (OBRIGATÓRIO)
# --------------------------------------------
# Token de acesso do GitHub
# Como criar: Settings → Developer settings → Personal access tokens → Tokens (classic)
# Permissões necessárias: repo, workflow
GITHUB_TOKEN=gph_"seu token aqui"

# --------------------------------------------
# DEBUG E LOGS
# --------------------------------------------
# Ativar logs detalhados para debug
# Valores: true / false
# Padrão: false
DEBUG=true

# --------------------------------------------
# RETRY E TIMEOUT
# --------------------------------------------
# Número máximo de tentativas em caso de falha
# Padrão: 3
MAX_RETRIES=3

# Delay entre tentativas (em milissegundos)
# Padrão: 2000 (2 segundos)
RETRY_DELAY=2000

# Timeout máximo para cada operação (em milissegundos)
# Padrão: 30000 (30 segundos)
TIMEOUT=30000

# --------------------------------------------
# VALIDAÇÃO DE REPOSITÓRIOS
# --------------------------------------------
# Sigla para filtrar repositórios
# Padrão: mov
SIGLA_VALIDA=mov

# Tipo de plataforma para filtrar
# Padrão: Mobile
TIPO_PLATAFORMA_VALIDO=Plataforma Mobile

# --------------------------------------------
# GITHUB e PULL REQUESTS
# --------------------------------------------

#Url para teste de conectividade do GH
GITHUB_API_URL=https://api.github.com

# Mensagem do commit ao criar/atualizar o arquivo
# Padrão: Adiciona arquivo CODEOWNERS
PR_COMMIT_MESSAGE=Adiciona arquivo CODEOWNERS

# Título do Pull Request
# Padrão: Adiciona arquivo CODEOWNERS
PR_TITLE=Adiciona arquivo CODEOWNERS

# Corpo/Descrição do Pull Request
# Padrão: Este PR adiciona automaticamente o arquivo CODEOWNERS ao repositório.
PR_BODY=Este PR adiciona automaticamente o arquivo CODEOWNERS ao repositório.

# --------------------------------------------
# CONFIGURAÇÕES DE ARQUIVO CODEOWNERS
# --------------------------------------------
# Caminho do arquivo CODEOWNERS no repositório
# Padrão: .github/CODEOWNERS
CODEOWNERS_PATH=.github/CODEOWNERS

# Conteúdo padrão do arquivo CODEOWNERS
# Use \n para quebra de linha
# Padrão: #Arquivo CODEOWNER CRIADO COM SUCESSO\n#PROPRIETARIOS DO DIRETORIO: 
CODEOWNERS_CONTENT=#Arquivo CODEOWNER CRIADO COM SUCESSO\n#PROPRIETARIOS DO DIRETORIO: @seu_usuario